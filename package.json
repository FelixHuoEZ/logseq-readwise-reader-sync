{
  "name": "logseq-readwise-reader-sync",
  "version": "0.1.8",
  "author": "FelixHuoEZ",
  "description": "Unofficial Reader v3 sync for Logseq.",
  "license": "MIT",
  "logseq": {
    "id": "felixhuoez-logseq-readwise-sync",
    "title": "Readwise Reader Sync",
    "icon": "./icon-v2.png",
    "main": "dist/index.html"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "package:plugin": "npm run build && node scripts/package-plugin.mjs",
    "diag:page-snapshot": "node scripts/raw-page-snapshot.mjs",
    "diag:reader-highlights": "node scripts/reader-highlight-dump.mjs",
    "diag:reader-v3-feasibility": "node scripts/reader-v3-feasibility.mjs",
    "prepare": "husky",
    "lint:precommit": "echo \"Running biome\" && biome check . --write && echo \"Running tsc\" && tsc --noEmit"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/github",
        {
          "assets": [
            "logseq-readwise-reader-sync.zip"
          ]
        }
      ]
    ]
  },
  "dependencies": {
    "@logseq/libs": "^0.2.11",
    "date-fns": "^4.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "wretch": "^3.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "typescript": "^5.5.4",
    "vite": "^7.3.0",
    "vite-plugin-logseq": "^1.1.2",
    "vite-tsconfig-paths": "^6.0.3"
  }
}
